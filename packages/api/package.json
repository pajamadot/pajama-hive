{
  "name": "@pajamadot/hive-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "build": "wrangler deploy --dry-run --outdir=dist",
    "deploy": "wrangler deploy",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@neondatabase/serverless": "^0.10.0",
    "@pajamadot/hive-shared": "workspace:*",
    "drizzle-orm": "^0.38.0",
    "hono": "^4.7.0",
    "nanoid": "^5.1.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250310.0",
    "drizzle-kit": "^0.30.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.0",
    "wrangler": "^3.110.0"
  }
}
